# Local-only release pipeline — no EAS Build, no CI.
#
# Signing credentials come from environment variables. For convenience they can live in
# a gitignored `fastlane/.env` file, which Fastlane auto-loads (dotenv) — or just export
# them in your shell. The keystore itself is a file on disk pointed at by
# ZIPPYFIT_UPLOAD_STORE_FILE. The values are passed to Gradle as -P project properties,
# which the withAndroidReleaseSigning config plugin reads. Nothing secret is committed.

require "shellwords"

# fastlane EVALUATES this Fastfile with CWD = fastlane/, but RUNS lane code and actions
# with CWD = the folder containing fastlane/ (mobile/). So resolve paths at lane runtime
# (where Dir.pwd is mobile/), not at load time — and use absolute paths so the `sh` and
# `gradle` actions, which have different base dirs, both agree.
def project_root
  # fastlane keeps Ruby's CWD at the fastlane/ folder during execution; the Expo
  # project root (mobile/) is its parent.
  root = File.expand_path("..", Dir.pwd)
  unless File.exist?(File.join(root, "package.json"))
    UI.user_error!("Expected the Expo project at #{root} but found no package.json there.")
  end
  root
end

def android_dir
  File.join(project_root, "android")
end

def aab_path
  File.join(android_dir, "app/build/outputs/bundle/release/app-release.aab")
end

SIGNING_ENV_KEYS = %w[
  ZIPPYFIT_UPLOAD_STORE_FILE
  ZIPPYFIT_UPLOAD_STORE_PASSWORD
  ZIPPYFIT_UPLOAD_KEY_ALIAS
  ZIPPYFIT_UPLOAD_KEY_PASSWORD
].freeze

# Read + validate signing env vars, returning the -P properties hash for Gradle.
def signing_properties
  missing = SIGNING_ENV_KEYS.select { |k| ENV[k].to_s.strip.empty? }
  unless missing.empty?
    UI.user_error!(
      "Missing signing env vars: #{missing.join(', ')}. " \
      "Export them or set them in fastlane/.env (see fastlane/README.md)."
    )
  end

  store = File.expand_path(ENV["ZIPPYFIT_UPLOAD_STORE_FILE"])
  UI.user_error!("Keystore not found at #{store}") unless File.exist?(store)

  {
    "ZIPPYFIT_UPLOAD_STORE_FILE" => store,
    "ZIPPYFIT_UPLOAD_STORE_PASSWORD" => ENV["ZIPPYFIT_UPLOAD_STORE_PASSWORD"],
    "ZIPPYFIT_UPLOAD_KEY_ALIAS" => ENV["ZIPPYFIT_UPLOAD_KEY_ALIAS"],
    "ZIPPYFIT_UPLOAD_KEY_PASSWORD" => ENV["ZIPPYFIT_UPLOAD_KEY_PASSWORD"]
  }
end

default_platform(:android)

platform :android do
  desc "Regenerate native project and build a signed release .aab locally"
  lane :build do
    props = signing_properties
    sh("cd #{project_root.shellescape} && npx expo prebuild -p android --clean")
    gradle(
      project_dir: android_dir,
      task: "bundle",
      build_type: "Release",
      properties: props
    )
    UI.success("Built #{aab_path}")
  end

  desc "Build, then upload to the Play Store internal track (listing must already exist)"
  lane :deploy do
    key = File.join(Dir.pwd, "play-store-key.json") # Dir.pwd is the fastlane/ folder
    unless File.exist?(key)
      UI.user_error!(
        "Missing fastlane/play-store-key.json (Play service-account key). " \
        "Add it per fastlane/README.md. Note: the FIRST release must be uploaded by " \
        "hand in Play Console — `deploy` only works once the app has an existing build."
      )
    end

    build
    upload_to_play_store(
      json_key: key,
      track: "internal",
      aab: aab_path,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "draft"
    )
  end
end

platform :ios do
  # Scaffolded for later. Requires a Mac + Xcode + App Store Connect API key.
  # Wire up `match`/`gym`/`pilot` when you're ready to ship iOS.
  desc "iOS release (not yet configured)"
  lane :deploy do
    UI.user_error!("iOS lane not configured yet — see README.md before enabling.")
  end
end
