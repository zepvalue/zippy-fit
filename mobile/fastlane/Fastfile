# Local-only release pipeline — no EAS Build, no cloud credits.
# The native android/ project is generated by `expo prebuild` (gitignored), so every
# lane regenerates it first. Release signing is injected by the withAndroidReleaseSigning
# config plugin from Gradle properties you set outside the repo (see README.md).

AAB_PATH = "../android/app/build/outputs/bundle/release/app-release.aab"

default_platform(:android)

platform :android do
  desc "Regenerate native project and build a signed release .aab locally"
  lane :build do
    sh("cd .. && npx expo prebuild -p android --clean")
    gradle(
      project_dir: "../android",
      task: "bundle",
      build_type: "Release"
    )
    UI.success("Built #{AAB_PATH}")
  end

  desc "Build, then upload to the Play Store internal track (listing must already exist)"
  lane :deploy do
    build
    upload_to_play_store(
      track: "internal",
      aab: AAB_PATH,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "draft"
    )
  end
end

platform :ios do
  # Scaffolded for later. Requires a Mac + Xcode + App Store Connect API key.
  # Wire up `match`/`gym`/`pilot` when you're ready to ship iOS.
  desc "iOS release (not yet configured)"
  lane :deploy do
    UI.user_error!("iOS lane not configured yet — see README.md before enabling.")
  end
end
