# Copy this to fastlane/.env (gitignored) and fill in the values, OR export these
# in your shell. Fastlane auto-loads fastlane/.env when you run a lane.
#
# The keystore is a file on disk — point STORE_FILE at it (absolute path or ~ both work).

ZIPPYFIT_UPLOAD_STORE_FILE=~/.zippyfit-upload.jks
ZIPPYFIT_UPLOAD_STORE_PASSWORD=
ZIPPYFIT_UPLOAD_KEY_ALIAS=zippyfit-upload
ZIPPYFIT_UPLOAD_KEY_PASSWORD=
